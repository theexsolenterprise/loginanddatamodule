# ──────────────────────────────────────────────────────────────────────────────
# Quidvis Login & Data Module — environment template
# Copy to `.env.local` for dev, or paste into Netlify → Site → Env Vars for prod.
# ──────────────────────────────────────────────────────────────────────────────

# ── Neon Postgres ─────────────────────────────────────────────────────────────
# Get from: https://console.neon.tech → your project → Connection Details → "Pooled connection"
# The serverless driver wants the POOLED URL (ends with `-pooler.<region>...`).
DATABASE_URL="postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require"

# Direct (non-pooled) URL — needed by drizzle-kit for migrations.
DATABASE_URL_UNPOOLED="postgresql://<user>:<password>@<host>.<region>.aws.neon.tech/<db>?sslmode=require"

# ── Auth.js ───────────────────────────────────────────────────────────────────
# Generate with:  openssl rand -base64 32
AUTH_SECRET="<paste-random-32-byte-base64>"

# Set to your deployed URL in prod (e.g. https://quidvis.netlify.app)
# Leave empty in dev — Auth.js infers http://localhost:3000
AUTH_URL=""

# Trust the host header behind Netlify's proxy
AUTH_TRUST_HOST="true"

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
#   1. "Create OAuth client ID" → Web application
#   2. Authorized JavaScript origins:   http://localhost:3000   AND   https://<your-netlify-domain>
#   3. Authorized redirect URIs:        http://localhost:3000/api/auth/callback/google
#                                       https://<your-netlify-domain>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ── Netlify Blobs ─────────────────────────────────────────────────────────────
# When running ON Netlify (Functions / SSR), these are injected automatically — leave blank.
# When running LOCALLY against the real Netlify Blobs service, set:
#   1. NETLIFY_SITE_ID  — from netlify.toml or the Netlify UI (Site settings → General → Site ID)
#   2. NETLIFY_AUTH_TOKEN — Personal access token from https://app.netlify.com/user/applications
# If both are blank in dev, the app falls back to a local on-disk store at ./.blobs/
NETLIFY_SITE_ID=""
NETLIFY_AUTH_TOKEN=""

# ── Gmail SMTP via OAuth (for invite + password-reset emails) ────────────────
# Uses the same OAuth client you created above for sign-in. Steps:
#   1. https://developers.google.com/oauthplayground/
#   2. Settings (gear) → "Use your own OAuth credentials" → paste AUTH_GOOGLE_ID + AUTH_GOOGLE_SECRET
#   3. In step 1, paste scope:  https://mail.google.com/
#   4. Authorize APIs → sign in with the Gmail account that will SEND the mail
#   5. Exchange authorization code for tokens → copy `refresh_token` below
GMAIL_SENDER=""             # e.g. you@gmail.com or noreply@yourdomain.com (if Workspace)
GMAIL_REFRESH_TOKEN=""

# Public URL of the app — used in email links. In dev: http://localhost:8888
APP_URL="http://localhost:8888"

# ── Admin bootstrap ───────────────────────────────────────────────────────────
# These seed the FIRST admin (you). Run `npm run db:seed` once.
ADMIN_EMAIL="theexsolenterprise@gmail.com"
ADMIN_PASSWORD="change-me-on-first-login"
ADMIN_FIRST_NAME="Ashish"
ADMIN_LAST_NAME="Admin"
